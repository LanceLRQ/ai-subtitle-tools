{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Subtitle Tools",
  "version": "0.1.0",
  "identifier": "com.ai-subtitle-tools.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3080",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": ".."
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": ".."
    }
  },
  "app": {
    "windows": [
      {
        "title": "AI视频字幕生成工具",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
